env native;

// Test break and continue statements - fixed limitation #5

int testBreak() {
    int x = 0;
    
    while (true) {
        x = x + 1;
        if (x == 5) {
            break;
        }
        x = x + 1;
    }
    
    return x;  // Should be 5
}

int testBreakInLoop() {
    int counter = 0;
    
    while (counter < 100) {
        counter = counter + 1;
        if (counter == 10) {
            break;  // Exit early
        }
    }
    
    return counter;  // Should be 10
}

int testContinue() {
    int sum = 0;
    int i = 0;
    
    while (i < 10) {
        i = i + 1;
        if (i == 5) {
            continue;  // Skip adding 5
        }
        sum = sum + i;
    }
    
    return sum;  // Should be 1+2+3+4+6+7+8+9+10 = 50
}

int testNestedBreak() {
    int outer = 0;
    int innerCount = 0;  // Declare outside loop
    
    while (outer < 5) {
        innerCount = 0;  // Reset each iteration
        while (innerCount < 5) {
            innerCount = innerCount + 1;
            if (innerCount == 3) {
                break;  // Break inner loop only
            }
        }
        outer = outer + 1;
    }
    
    return outer;  // Should be 5
}

int r1 = testBreak();
int r2 = testBreakInLoop();
int r3 = testContinue();
int r4 = testNestedBreak();

printf("testBreak() = %lld (expected 5)\n", r1);
printf("testBreakInLoop() = %lld (expected 10)\n", r2);
printf("testContinue() = %lld (expected 50)\n", r3);
printf("testNestedBreak() = %lld (expected 5)\n", r4);
