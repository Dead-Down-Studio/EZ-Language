env native;

// Test 1: Basic float variable
float x = 3.14;
print("Test 1 - Basic float: 3.14");
print(x);

// Test 2: Float arithmetic
float a = 2.5;
float b = 1.5;
float sum = a + b;
print("Test 2 - Float addition: 2.5 + 1.5 = 4.0");
print(sum);

// Test 3: Float multiplication
float c = 2.0;
float d = 3.5;
float product = c * d;
print("Test 3 - Float multiplication: 2.0 * 3.5 = 7.0");
print(product);

// Test 4: Mixed int/float arithmetic (should promote to float)
int i = 5;
float f = 2.5;
float mixed = i + f;
print("Test 4 - Mixed arithmetic: 5 + 2.5 = 7.5");
print(mixed);

// Test 5: Float comparison
float v1 = 3.14;
float v2 = 2.71;
if (v1 > v2) {
    print("Test 5 - Comparison: 3.14 > 2.71 = true");
}

// Test 6: Float default initialization
float default_val;
print("Test 6 - Default float should be 0.0:");
print(default_val);

// Test 7: Float assignment
float mutable = 1.0;
mutable = 2.0;
mutable = mutable + 1.0;
print("Test 7 - Float assignment should be 3.0:");
print(mutable);

// Test 8: Float in loop
float counter = 0.0;
int iterations = 0;
while (counter < 5.0) {
    counter = counter + 0.5;
    iterations = iterations + 1;
}
print("Test 8 - Float loop iterations should be 10:");
print(iterations);
print("Test 8 - Final counter should be 5.0:");
print(counter);
