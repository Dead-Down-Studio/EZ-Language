env native;

// Test assignment statements - fixed limitation #1

int testBasicAssignment() {
    int x = 10;
    x = 20;  // Assignment statement!
    return x;
}

int testMultipleAssignments() {
    int counter = 0;
    counter = counter + 1;
    counter = counter + 1;
    counter = counter + 1;
    return counter;
}

int testLoopWithAssignment() {
    int sum = 0;
    int i = 1;
    
    while (i <= 5) {
        sum = sum + i;
        i = i + 1;
    }
    
    return sum;  // Should be 1+2+3+4+5 = 15
}

boolean testBooleanAssignment() {
    boolean flag = true;
    flag = false;
    flag = true;
    return flag;
}

int r1 = testBasicAssignment();
int r2 = testMultipleAssignments();
int r3 = testLoopWithAssignment();  
boolean r4 = testBooleanAssignment();

printf("testBasicAssignment() = %lld (expected 20)\n", r1);
printf("testMultipleAssignments() = %lld (expected 3)\n", r2);
printf("testLoopWithAssignment() = %lld (expected 15)\n", r3);
printf("testBooleanAssignment() = %lld (expected 1/true)\n", r4);
