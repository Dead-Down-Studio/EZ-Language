env native;

friend float_math: cpp as math;

// Test float friend calls
float x = 3.0;
float result = math.square(x);
print("Test: square(3.0) should be 9.0:");
print(result);

float y = 16.0;
float sqrt_result = math.sqrt_wrapper(y);
print("Test: sqrt(16.0) should be 4.0:");
print(sqrt_result);

float a = 2.5;
float b = 3.5;
float sum = math.add(a, b);
print("Test: add(2.5, 3.5) should be 6.0:");
print(sum);

// Test mixed int/float with friend calls
float i = 5.0;
float mixed = math.square(i);
print("Test: square(5.0) should be 25.0:");
print(mixed);
