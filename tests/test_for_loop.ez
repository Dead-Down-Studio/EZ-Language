env native;

int sumDeclaredInit() {
    int total = 0;

    for (int i = 0; i < 5; i = i + 1) {
        total = total + i;
    }

    return total; // 0+1+2+3+4 = 10
}

int sumAssignedInit() {
    int i = 0;
    int total = 0;

    for (i = 1; i <= 4; i = i + 1) {
        total = total + i;
    }

    return total + i; // 10 + 5 = 15
}

int testBreakInFor() {
    int seen = 0;

    for (int i = 0; i < 10; i = i + 1) {
        if (i == 3) {
            break;
        }
        seen = seen + 1;
    }

    return seen; // 3
}

int testContinueInFor() {
    int count = 0;

    for (int i = 0; i < 6; i = i + 1) {
        if (i == 2) {
            continue;
        }
        count = count + 1;
    }

    return count; // 5
}

int r1 = sumDeclaredInit();
int r2 = sumAssignedInit();
int r3 = testBreakInFor();
int r4 = testContinueInFor();

printf("sumDeclaredInit = %lld (expected 10)\n", r1);
printf("sumAssignedInit = %lld (expected 15)\n", r2);
printf("testBreakInFor = %lld (expected 3)\n", r3);
printf("testContinueInFor = %lld (expected 5)\n", r4);
