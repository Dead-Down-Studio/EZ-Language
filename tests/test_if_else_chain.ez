env native;

int classify(int x) {
    if (x == 0) {
        return 0;
    } else if (x < 5) {
        return 10;
    } else if (x < 10) {
        return 20;
    } else {
        return 30;
    }
}

int a = classify(0);
int b = classify(3);
int c = classify(7);
int d = classify(15);

printf("classify(0) = %lld\n", a);
printf("classify(3) = %lld\n", b);
printf("classify(7) = %lld\n", c);
printf("classify(15) = %lld\n", d);
