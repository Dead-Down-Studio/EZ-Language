env native;

// Test comprehensive control flow - all limitations fixed!

int fibonacci(int n) {
    if (n <= 1) {
        return n;
    }
    
    int a = 0;
    int b = 1;
    int i = 2;
    int temp = 0;  // Declare outside loop
    
    while (i <= n) {
        temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    
    return b;
}

int factorial(int n) {
    int result = 1;
    int i = 1;
    
    while (i <= n) {
        result = result * i;
        i = i + 1;
    }
    
    return result;
}

int countEven(int max) {
    int count = 0;
    int i = 0;  // Start at 0 (even)
    
    while (i <= max) {
        count = count + 1;
        i = i + 2;  // Skip by 2 to get only evens: 0,2,4,6...
    }
    
    return count;
}

int searchValue(int target) {
    int i = 1;
    boolean found = false;
    int result = 0;
    
    while (i <= 100) {
        if (i == target) {
            result = i;
            found = true;
            break;  // Found it!
        }
        i = i + 1;
    }
    
    return result;  // Returns target if found, 0 if not
}

int fib5 = fibonacci(5);
int fib10 = fibonacci(10);
int fact5 = factorial(5);
int evens20 = countEven(20);
int found = searchValue(42);

printf("fibonacci(5) = %lld (expected 5)\n", fib5);
printf("fibonacci(10) = %lld (expected 55)\n", fib10);
printf("factorial(5) = %lld (expected 120)\n", fact5);
printf("countEven(20) = %lld (expected 11)\n", evens20);
printf("searchValue(42) = %lld (expected 42)\n", found);
