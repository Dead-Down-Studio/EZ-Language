env native;

// Test if statement execution

int testSimpleIf(int x) {
    if (x > 10) {
        return 100;
    }
    return 0;
}

int testIfWithBool(boolean flag) {
    if (flag) {
        return 1;
    }
    return 0;
}

int a = 15;
int b = 5;

int result1 = testSimpleIf(a);
int result2 = testSimpleIf(b);
int result3 = testIfWithBool(true);
int result4 = testIfWithBool(false);

printf("testSimpleIf(15) = %lld\n", result1);
printf("testSimpleIf(5) = %lld\n", result2);
printf("testIfWithBool(true) = %lld\n", result3);
printf("testIfWithBool(false) = %lld\n", result4);
