env native;

// Test while loop execution
// Note: Grammar doesn't support assignment expressions yet
// So we test basic loop condition checking

int testWhileFalse() {
    int x = 0;
    
    // This loop won't execute at all
    while (false) {
        int y = 10;  // This won't execute
    }
    
    return x;  // Should return 0
}

int testWhileCondition(int n) {
    int result = 42;
    
    // Loop that checks condition
    while (n > 10) {
        int temp = 100;  // This executes but doesn't affect result
        return 999;  // Return from inside loop if it executes
    }
    
    return result;  // Return 42 if loop doesn't execute
}

int r1 = testWhileFalse();
int r2 = testWhileCondition(5);   // 5 > 10 is false, returns 42
int r3 = testWhileCondition(15);  // 15 > 10 is true, returns 999

printf("testWhileFalse() = %lld (expected 0)\n", r1);
printf("testWhileCondition(5) = %lld (expected 42)\n", r2);
printf("testWhileCondition(15) = %lld (expected 999)\n", r3);
