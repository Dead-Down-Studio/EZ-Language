env native;
friend native_math: cpp as m;

boolean t = true;
boolean f = false;

int addTrue = m.add(t, 2);
int addFalse = m.add(f, 2);
int multTrue = m.mult(t, 5);
int multFalse = m.mult(f, 5);

printf("add(true,2) = %lld (expected 3)\n", addTrue);
printf("add(false,2) = %lld (expected 2)\n", addFalse);
printf("mult(true,5) = %lld (expected 5)\n", multTrue);
printf("mult(false,5) = %lld (expected 0)\n", multFalse);
